# ----------------------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------------------
POSTGRES_DB=mailserver
POSTGRES_USER=mail
POSTGRES_PASSWORD=change-this-strong-password

# ----------------------------------------------------------------------------
# Mail identity
# ----------------------------------------------------------------------------
# Default root domain. Mailboxes are <user>@mail.<tenant>.<root>.
ROOT_DOMAIN=example.com
# Public MX hostname (its A record must point to this server's IP).
MAIL_HOSTNAME=mx1.example.com

# ----------------------------------------------------------------------------
# Admin API auth — generate a long random token, e.g. `openssl rand -hex 24`
# ----------------------------------------------------------------------------
ADMIN_API_TOKEN=change-this-long-random-token

# ----------------------------------------------------------------------------
# Cloudflare (optional — enables automatic MX record management)
# ----------------------------------------------------------------------------
# Global fallback token + zone, used when a root domain has no token of its own.
CF_API_TOKEN=
CF_ZONE_ID=

# Multi-root SEED (optional). Root domains are stored in the `root_domains`
# table and managed from the web console / API at runtime. This variable is
# only read ONCE to seed an empty table on first boot — editing it later has
# no effect. After first boot, manage roots in the "Root Domains" page.
# Format: "root1:zoneid1[:token1],root2:zoneid2[:token2],..."
# token is optional and falls back to CF_API_TOKEN.
# Example:
# ROOT_DOMAINS=example.com:<zone_id_1>,example.net:<zone_id_2>:<cf_token_2>
ROOT_DOMAINS=
